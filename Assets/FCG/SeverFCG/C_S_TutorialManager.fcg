import "StdLibrary.fcc" as StdLib
import "EditorGenLib.fcc" as EditorLib

graph PlayerTutorial {
    isDoneFishingTutorial bool

    func SetIsDoneFishingTutorial(value bool) {
        isDoneFishingTutorial = value
    }

    func GetIsDoneFishingTutorial() bool {
        return isDoneFishingTutorial
    }
}