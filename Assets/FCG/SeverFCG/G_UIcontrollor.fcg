// 一比一转换自 G_UIcontrollor.eca（未修改 ECA）
// variables: Climbing_button(Map), VisibleUI(CustomHud), InvisibleUI(CustomHud), Climbing_UI(Map)
// OnAwake -> grs Climbing_button=New Map(Player,CustomHud); grs Climbing_UI=New Map(Player,CustomHud)
// slr signal_36346128(player) -> PrintString("1") -> ife1 MapContainKey? prs OpenState:CustomHud=true : CreateCustomHudV2+MapSetValue
// slr signal_87440986(player) -> prs OpenState:CustomHud=false
// slr signal_44946959(player,height) -> prs AnchorPosition:HudWidget=NewVector(-331,height,0)
// e OnPlayerAdd(Player) -> CreateCustomHudV2 x2 -> MapSetValue(Climbing_UI,Player,Created Entity2) -> PrintString(Climbing_UI)

import "StdLibrary.fcc" as std
import "Map.fcc" as map
import "List.fcc" as list
import "Player.fcc" as player
import "Hud.fcc" as hud
import "EditorGenLib.fcc" as gen
import "Convert.fcc" as convert
import "Math.fcc" as math
import "./G_economy.fcg" as G_economy
import "./S_power.fcg" as S_power


[platform_server]
graph G_UIcontrollor {
	Climbing_button Map<object, object> = nil
	VisibleUI entity = nil
	InvisibleUI entity = nil
	Climbing_UI Map<object, object> = nil
	P_IngameHud_ByPlayer Map<object, object> = nil
	Realtime_Height Map<object, object> = nil
	Current_Speed Map<object, object> = nil
	GoldCoin_Widget Map<object, object> = nil
	GoldCoin_Muti_Widget Map<object, object> = nil
	DEnough_UI_ByPlayer Map<object, object> = nil
	DEnough_Text_ByPlayer Map<object, object> = nil
	DEnough_ShowToken Map<object, object> = nil
	Tired_UI_ByPlayer Map<object, object> = nil
	Tired_ShowToken Map<object, object> = nil
	Beginners_Guide_UI Map<object, object> = nil
	BeginnerGuide_Stage Map<object, object> = nil


	event OnAwake() {
		LogInfo("G_UIcontrollorOnAwake")
		Climbing_button = map.New()
		Climbing_UI = map.New()
		P_IngameHud_ByPlayer = map.New()
		Realtime_Height = map.New()
		Current_Speed = map.New()
		GoldCoin_Widget = map.New()
		GoldCoin_Muti_Widget = map.New()
		DEnough_UI_ByPlayer = map.New()
		DEnough_Text_ByPlayer = map.New()
		DEnough_ShowToken = map.New()
		Tired_UI_ByPlayer = map.New()
		Tired_ShowToken = map.New()
		Beginners_Guide_UI = map.New()
		BeginnerGuide_Stage = map.New()
	}

	event OnPlayerJoin(player entity<Player>) {
		ApplyDefaultHudVisibility(player)
		CreateCustomUI(out var G_IngamHud, player, EResUI.G_IngamHud)
		CreateCustomUI(out var Avatar, nil, EResUI.Avatar)
		CreateCustomUI(out var P_IngameHudEntity, player, EResUI.P_IngameHud)
		CreateCustomUI(out var DEnoughEntity, player, EResUI.DEnough)
		CreateCustomUI(out var TiredEntity, player, EResUI.Tired)
		Climbing_UI[player] = Avatar
		P_IngameHud_ByPlayer[player] = P_IngameHudEntity
		DEnough_UI_ByPlayer[player] = DEnoughEntity
		Tired_UI_ByPlayer[player] = TiredEntity
		DEnough_ShowToken[player] = 0
		Tired_ShowToken[player] = 0
		var labelWidget = GetWidgetByPath(player, Avatar as entity<CustomUI>, "/Panel (1)/Realtime_Height")
		if labelWidget != nil {
			Realtime_Height[player] = labelWidget
		}
		var avatarProfileWidget = GetWidgetByPath(player, Avatar as entity<CustomUI>, "/Panel (1)/Avatar (1)")
		if avatarProfileWidget != nil {
			avatarProfileWidget<UIWidgetProfile>.AccountID = player<Player>.UserUID
		}
		var avatarNameWidget = GetWidgetByPath(player, Avatar as entity<CustomUI>, "/Panel (1)/name")
		if avatarNameWidget != nil {
			avatarNameWidget<HudLabelWidget>.Text = player<Player>.NickName
		}
		var currentSpeedWidget = GetWidgetByPath(player, P_IngameHudEntity as entity<CustomUI>, "/Current_Speed")
	
		if currentSpeedWidget != nil {
			LogInfo("currentSpeedWidget2: " + currentSpeedWidget)
			Current_Speed[player] = currentSpeedWidget
		}
		var goldCoinWidget = GetWidgetByPath(player, P_IngameHudEntity as entity<CustomUI>, "/GoldCoin")
		if goldCoinWidget != nil {
			var gold float = 0.0
			GoldCoin_Widget[player] = goldCoinWidget
			if !ContainKey(globalEntity<G_economy>.PlayerGold, player) {
				gold = 0.0
			} else {
				gold = globalEntity<G_economy>.PlayerGold[player]
			}
			goldCoinWidget<HudLabelWidget>.Text = FormatBigNumber(gold)
		}
		var goldCoinMutiWidget = GetWidgetByPath(player, P_IngameHudEntity as entity<CustomUI>, "/Goldcoin_muti")
		if goldCoinMutiWidget != nil {
			GoldCoin_Muti_Widget[player] = goldCoinMutiWidget
			SetGoldCoinMultiplierUI(player, globalEntity<S_power>.GetPlayerPowerValue(player))
		}
		if DEnoughEntity != nil {
			DEnoughEntity<CustomUI>.IsVisible = false
			var dEnoughTextWidget = GetWidgetByPath(player, DEnoughEntity as entity<CustomUI>, "/Text")
			if dEnoughTextWidget != nil {
				DEnough_Text_ByPlayer[player] = dEnoughTextWidget
				dEnoughTextWidget<UIWidget>.IsVisible = false
			}
		}
		if TiredEntity != nil {
			TiredEntity<CustomUI>.IsVisible = false
		}
		var ingameUIMap = map.New()
		ingameUIMap["P_IngameHud"] = P_IngameHudEntity
		DispatchEventToEntity(__Custom6event_CreateIngameUI__, player, PlatformType.Client, List<object>{ingameUIMap})

		// 创建新手指引 UI，隐藏所有元素，只显示 /Summon
		/*CreateCustomUI(out var beginnerGuideEntity, player, EResUI.Beginners_Guide)
		Beginners_Guide_UI[player] = beginnerGuideEntity
		BeginnerGuide_Stage[player] = 0
		var bgSummon = GetWidgetByPath(player, beginnerGuideEntity as entity<CustomUI>, "/Summon")
		var bgClimbing = GetWidgetByPath(player, beginnerGuideEntity as entity<CustomUI>, "/Climbing")
		var bgBuy = GetWidgetByPath(player, beginnerGuideEntity as entity<CustomUI>, "/Buy")
		if bgSummon != nil {
			bgSummon<UIWidget>.IsVisible = true
		}
		if bgClimbing != nil {
			bgClimbing<UIWidget>.IsVisible = false
		}
		if bgBuy != nil {
			bgBuy<UIWidget>.IsVisible = false
		}*/
		
	}

