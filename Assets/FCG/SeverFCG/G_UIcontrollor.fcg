	event __Custom6event_entertrigger__(player entity<Player>) {
	}

	event __Custom6event_ClimbStateChanged__(player entity<Player>, bIsClimb bool, bIsFall bool, ishanging bool) {
	}
	event __Custom6event_SetCurrentSpeed__(player entity<Player>, Nominal_Speed float) {
	
		if ContainKey(Current_Speed, player) {
			var speedWidget = Current_Speed[player] as entity
			LogInfo("speedWidget: " + speedWidget)
			if speedWidget != nil {
				speedWidget<HudLabelWidget>.Text = FormatFixed2ByRound(Nominal_Speed)
			}
		}
	}
	event __Custom6event_leavetrigger__(player entity<Player>) {
		if !ContainKey(Climbing_button, player) {
			return
		}
		var hudEntity = Climbing_button[player] as entity
		if hudEntity != nil {
			hudEntity<CustomUI>.IsVisible = false
		}
	}

	event __Custom6event_ClimbUI__(player entity<Player>, height float) {
		var customHud = Climbing_UI[player]
		var AvetarPanleEntity = GetWidgetByPath(player, customHud as entity<CustomUI>, "/Panel (1)")
		AvetarPanleEntity<UIWidget>.AnchorPosition = Vector3{-331, height, 0}
	
		
	}
	event __Custom6event6_ReportHeight__( player entity<Player>,  height float) {
		if ContainKey(Realtime_Height, player) {
			var labelWidget = Realtime_Height[player] as entity
			if labelWidget != nil {
				var displayHeight int= math.Round(height)
				labelWidget<HudLabelWidget>.Text = convert.NumToString(displayHeight, 0)
			}
		}
	}
	// 经济值变更时由 G_economy 派发，将 P_IngameHud/GoldCoin 文本更新为字典中对应数值
	event Custom_eventGoldChanged(player entity<Player>, gold float) {
		if !ContainKey(GoldCoin_Widget, player) {
			return
		}
		var goldCoinWidget = GoldCoin_Widget[player] as entity
		if goldCoinWidget != nil {
			goldCoinWidget<HudLabelWidget>.Text = FormatBigNumber(gold)
		}
	}

	func SetGoldCoinMultiplierUI(player entity<Player>, powerValue float) {
		if !ContainKey(GoldCoin_Muti_Widget, player) {
			return
		}
		var goldCoinMutiWidget = GoldCoin_Muti_Widget[player] as entity
		if goldCoinMutiWidget != nil {
			goldCoinMutiWidget<HudLabelWidget>.Text = globalEntity<S_power>.FormatPowerDisplayValue(powerValue)
		}
	}

	event __Custom6event_ShowDEnough________(player entity<Player>, tipText string) {
		if !ContainKey(DEnough_UI_ByPlayer, player) {
			return
		}
		var dEnoughUI = DEnough_UI_ByPlayer[player] as entity
		if dEnoughUI == nil {
			return
		}
		dEnoughUI<CustomUI>.IsVisible = true
		if ContainKey(DEnough_Text_ByPlayer, player) {
			var dEnoughTextWidget = DEnough_Text_ByPlayer[player] as entity
			if dEnoughTextWidget != nil {
				dEnoughTextWidget<UIWidget>.IsVisible = true
				dEnoughTextWidget<HudLabelWidget>.Text = tipText
			}
		}
		var showToken = 1
		if ContainKey(DEnough_ShowToken, player) {
			showToken = (DEnough_ShowToken[player] as int) + 1
		}
		DEnough_ShowToken[player] = showToken
		start HideDEnoughDelayed(player, showToken)
	}

	async func HideDEnoughDelayed(player entity<Player>, showToken int) {
		WaitForMillisecond(2000)
		if !ContainKey(DEnough_ShowToken, player) {
			return
		}
		if (DEnough_ShowToken[player] as int) != showToken {
			return
		}
		SetDEnoughVisible(player, false)
	}

	func SetDEnoughVisible(player entity<Player>, visible bool) {
		if ContainKey(DEnough_UI_ByPlayer, player) {
			var dEnoughUI = DEnough_UI_ByPlayer[player] as entity
			if dEnoughUI != nil {
				dEnoughUI<CustomUI>.IsVisible = visible
			}
		}
		if ContainKey(DEnough_Text_ByPlayer, player) {
			var dEnoughTextWidget = DEnough_Text_ByPlayer[player] as entity
			if dEnoughTextWidget != nil {
				dEnoughTextWidget<UIWidget>.IsVisible = visible
			}
		}
	}

	event __Custom6event_ShowTired______(player entity<Player>) {
		if !ContainKey(Tired_UI_ByPlayer, player) {
			return
		}
		var tiredUI = Tired_UI_ByPlayer[player] as entity
		if tiredUI == nil {
			return
		}
		tiredUI<CustomUI>.IsVisible = true
		var showToken = 1
		if ContainKey(Tired_ShowToken, player) {
			showToken = (Tired_ShowToken[player] as int) + 1
		}
		Tired_ShowToken[player] = showToken
		start HideTiredDelayed(player, showToken)
	}

	async func HideTiredDelayed(player entity<Player>, showToken int) {
		WaitForMillisecond(2000)
		if !ContainKey(Tired_ShowToken, player) {
			return
		}
		if (Tired_ShowToken[player] as int) != showToken {
			return
		}
		SetTiredVisible(player, false)
	}

	func SetTiredVisible(player entity<Player>, visible bool) {
		if !ContainKey(Tired_UI_ByPlayer, player) {
			return
		}
		var tiredUI = Tired_UI_ByPlayer[player] as entity
		if tiredUI != nil {
			tiredUI<CustomUI>.IsVisible = visible
		}
	}

	func FormatFixed2ByRound(value float) string {
		var scaled = math.Round(value * 100.0)
		var sign = ""
		if scaled < 0 {
			sign = "-"
			scaled = -scaled
		}
		var integerPart = scaled / 100
		var decimalPart = scaled - integerPart * 100
		var decimalStr = convert.ToString(decimalPart)
		if decimalPart < 10 {
			decimalStr = "0" + decimalStr
		}
		return sign + convert.ToString(integerPart) + "." + decimalStr
	}

	// 新手引导：玩家成功召唤塔后，隐藏 /Summon，显示 /Climbing
	event __Custom6event__Custom6event_TutorialTowerSpawned____(player entity<Player>) {
		if !ContainKey(BeginnerGuide_Stage, player) {
			return
		}
		if (BeginnerGuide_Stage[player] as int) != 0 {
			return
		}
		BeginnerGuide_Stage[player] = 1
		if !ContainKey(Beginners_Guide_UI, player) {
			return
		}
		var guideUI = Beginners_Guide_UI[player] as entity
		if guideUI == nil {
			return
		}
		var bgSummon = GetWidgetByPath(player, guideUI as entity<CustomUI>, "/Summon")
		var bgClimbing = GetWidgetByPath(player, guideUI as entity<CustomUI>, "/Climbing")
		if bgSummon != nil {
			bgSummon<UIWidget>.IsVisible = false
		}
		if bgClimbing != nil {
			bgClimbing<UIWidget>.IsVisible = true
		}
	}

	// 新手引导：玩家攀爬落地后，隐藏 /Climbing，显示 /Buy
	event __Custom6event__Custom6event_TutorialPlayerLanded____(player entity<Player>) {
		if !ContainKey(BeginnerGuide_Stage, player) {
			return
		}
		if (BeginnerGuide_Stage[player] as int) != 1 {
			return
		}
		BeginnerGuide_Stage[player] = 2
		if !ContainKey(Beginners_Guide_UI, player) {
			return
		}
		var guideUI = Beginners_Guide_UI[player] as entity
		if guideUI == nil {
			return
		}
		var bgClimbing = GetWidgetByPath(player, guideUI as entity<CustomUI>, "/Climbing")
		var bgBuy = GetWidgetByPath(player, guideUI as entity<CustomUI>, "/Buy")
		if bgClimbing != nil {
			bgClimbing<UIWidget>.IsVisible = false
		}
		if bgBuy != nil {
			bgBuy<UIWidget>.IsVisible = true
		}
	}

	// 新手引导：玩家进入商店后，隐藏整个 Beginners_Guide UI
	event __Custom6event_WingshopEnter__(player entity<Player>) {
		if !ContainKey(BeginnerGuide_Stage, player) {
			return
		}
		if (BeginnerGuide_Stage[player] as int) >= 3 {
			return
		}
		BeginnerGuide_Stage[player] = 3
		if !ContainKey(Beginners_Guide_UI, player) {
			return
		}
		var guideUI = Beginners_Guide_UI[player] as entity
		if guideUI == nil {
			return
		}
		guideUI<CustomUI>.IsVisible = false
	}

	func FormatBigNumber(value float) string {
		if value < 1000.0 {
			
			return FormatFixed2ByRound(value)
		}
		if value < 1000000.0 {
			return FormatFixed2ByRound(value / 1000.0) + "K"
		}
		if value < 1000000000.0 {
			return FormatFixed2ByRound(value / 1000000.0) + "M"
		}
		if value < 1000000000000.0 {
			return FormatFixed2ByRound(value / 1000000000.0) + "B"
		}
		if value < 1000000000000000.0 {
			return FormatFixed2ByRound(value / 1000000000000.0) + "T"
		}
		if value < 1000000000000000000.0 {
			return FormatFixed2ByRound(value / 1000000000000000.0) + "Qa"
		}
		if value < 1000000000000000000000.0 {
			return FormatFixed2ByRound(value / 1000000000000000000.0) + "Qi"
		}
		if value < 1000000000000000000000000.0 {
			return FormatFixed2ByRound(value / 1000000000000000000000.0) + "Sx"
		}
		if value < 1000000000000000000000000000.0 {
			return FormatFixed2ByRound(value / 1000000000000000000000000.0) + "Sp"
		}
		if value < 1000000000000000000000000000000.0 {
			return FormatFixed2ByRound(value / 1000000000000000000000000000.0) + "Oc"
		}
		return FormatFixed2ByRound(value / 1000000000000000000000000000000.0) + "No"
	}
}
