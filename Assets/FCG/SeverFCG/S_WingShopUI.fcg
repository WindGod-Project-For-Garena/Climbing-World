	// 按解锁数量应用 BUY/Trick/Locked 显隐：unlockCount 0=仅 Wing1/BUY 可见；≥1 时 Wing1/Trick 可见、Wing1/Locked 不可视，依次类推
	func ApplyWingBuyState(player entity<Player>, wingshopUI entity<CustomUI>, unlockCount int) {
		var b1 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings1/BUY")
		var b2 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings2/BUY")
		var b3 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings3/BUY")
		var b4 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings4/BUY")
		var b5 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings5/BUY")
		var b6 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings6/BUY")
		var b7 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings7/BUY")
		var b8 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings8/BUY")
		var b9 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings9/BUY")
		var b10 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings10/BUY")
		var b11 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings11/BUY")
		var b12 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings12/BUY")
		var t1 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings1/Trick")
		var t2 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings2/Trick")
		var t3 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings3/Trick")
		var t4 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings4/Trick")
		var t5 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings5/Trick")
		var t6 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings6/Trick")
		var t7 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings7/Trick")
		var t8 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings8/Trick")
		var t9 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings9/Trick")
		var t10 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings10/Trick")
		var t11 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings11/Trick")
		var t12 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings12/Trick")
		var l1 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings1/Locked")
		var l2 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings2/Locked")
		var l3 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings3/Locked")
		var l4 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings4/Locked")
		var l5 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings5/Locked")
		var l6 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings6/Locked")
		var l7 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings7/Locked")
		var l8 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings8/Locked")
		var l9 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings9/Locked")
		var l10 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings10/Locked")
		var l11 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings11/Locked")
		var l12 = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings12/Locked")
		// BUY：仅下一个待解锁的显示
		if b1 != nil { b1<UIWidget>.IsVisible = (unlockCount == 0) }
		if b2 != nil { b2<UIWidget>.IsVisible = (unlockCount == 1) }
		if b3 != nil { b3<UIWidget>.IsVisible = (unlockCount == 2) }
		if b4 != nil { b4<UIWidget>.IsVisible = (unlockCount == 3) }
		if b5 != nil { b5<UIWidget>.IsVisible = (unlockCount == 4) }
		if b6 != nil { b6<UIWidget>.IsVisible = (unlockCount == 5) }
		if b7 != nil { b7<UIWidget>.IsVisible = (unlockCount == 6) }
		if b8 != nil { b8<UIWidget>.IsVisible = (unlockCount == 7) }
		if b9 != nil { b9<UIWidget>.IsVisible = (unlockCount == 8) }
		if b10 != nil { b10<UIWidget>.IsVisible = (unlockCount == 9) }
		if b11 != nil { b11<UIWidget>.IsVisible = (unlockCount == 10) }
		if b12 != nil { b12<UIWidget>.IsVisible = (unlockCount == 11) }
		// Trick：已解锁的显示
		if t1 != nil { t1<UIWidget>.IsVisible = (unlockCount >= 1) }
		if t2 != nil { t2<UIWidget>.IsVisible = (unlockCount >= 2) }
		if t3 != nil { t3<UIWidget>.IsVisible = (unlockCount >= 3) }
		if t4 != nil { t4<UIWidget>.IsVisible = (unlockCount >= 4) }
		if t5 != nil { t5<UIWidget>.IsVisible = (unlockCount >= 5) }
		if t6 != nil { t6<UIWidget>.IsVisible = (unlockCount >= 6) }
		if t7 != nil { t7<UIWidget>.IsVisible = (unlockCount >= 7) }
		if t8 != nil { t8<UIWidget>.IsVisible = (unlockCount >= 8) }
		if t9 != nil { t9<UIWidget>.IsVisible = (unlockCount >= 9) }
		if t10 != nil { t10<UIWidget>.IsVisible = (unlockCount >= 10) }
		if t11 != nil { t11<UIWidget>.IsVisible = (unlockCount >= 11) }
		if t12 != nil { t12<UIWidget>.IsVisible = (unlockCount >= 12) }
		// Locked：未解锁的显示，已解锁的不可视
		if l1 != nil { l1<UIWidget>.IsVisible = (unlockCount < 1) }
		if l2 != nil { l2<UIWidget>.IsVisible = (unlockCount < 2) }
		if l3 != nil { l3<UIWidget>.IsVisible = (unlockCount < 3) }
		if l4 != nil { l4<UIWidget>.IsVisible = (unlockCount < 4) }
		if l5 != nil { l5<UIWidget>.IsVisible = (unlockCount < 5) }
		if l6 != nil { l6<UIWidget>.IsVisible = (unlockCount < 6) }
		if l7 != nil { l7<UIWidget>.IsVisible = (unlockCount < 7) }
		if l8 != nil { l8<UIWidget>.IsVisible = (unlockCount < 8) }
		if l9 != nil { l9<UIWidget>.IsVisible = (unlockCount < 9) }
		if l10 != nil { l10<UIWidget>.IsVisible = (unlockCount < 10) }
		if l11 != nil { l11<UIWidget>.IsVisible = (unlockCount < 11) }
		if l12 != nil { l12<UIWidget>.IsVisible = (unlockCount < 12) }
	}

	// 控制 /Wings{N}/BUY_F 整体面板显隐：unlockCount+1 对应的翅膀面板可见，其余隐藏
	func ApplyBUY_FPanelState(player entity<Player>, wingshopUI entity<CustomUI>, unlockCount int) {
		var nextIndex = unlockCount + 1
		for i = 1, 13, 1 {
			var panel = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/Layout/Wings" + i + "/BUY_F")
			if panel != nil {
				panel<UIWidget>.IsVisible = (i == nextIndex)
			}
		}
	}

	func SetNotEnoughCupVisible(player entity<Player>, wingshopUI entity<CustomUI>, visible bool) {
		var tip = GetWidgetByPath(player, wingshopUI, "/Panel/Roll/not enough cup (1)")
		if tip != nil {
			tip<UIWidget>.IsVisible = visible
		}
	}

	func ShowNotEnoughCupForTwoSeconds(player entity<Player>, wingshopUI entity<CustomUI>) {
		SetNotEnoughCupVisible(player, wingshopUI, true)
		start HideNotEnoughCupDelayed(player, wingshopUI)
	}

	async func HideNotEnoughCupDelayed(player entity<Player>, wingshopUI entity<CustomUI>) {
		WaitForMillisecond(2000)
		if !ContainKey(Wingshop, player) {
			return
		}
		var currentUI = Wingshop[player] as entity<CustomUI>
		if currentUI == nil || currentUI != wingshopUI {
			return
		}
		SetNotEnoughCupVisible(player, currentUI, false)
	}
}
