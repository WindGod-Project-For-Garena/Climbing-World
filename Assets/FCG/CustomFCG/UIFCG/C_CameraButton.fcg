import "Player.fcc" as playerlib
[platform_client]
graph C_CameraButton {
  
    
    event  OnToggle(player entity<Player>, status bool) {
        LogInfo("C_CameraButton OnPressed")
    
        DispatchEventToEntity(__Custom6event_CameraButton____, globalEntity, PlatformType.Server, List<object>{player,status})
    }
}