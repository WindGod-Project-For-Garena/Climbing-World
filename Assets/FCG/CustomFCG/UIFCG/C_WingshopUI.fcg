// Wingshop 根节点挂载的客户端脚本
// 点击 Button 时将 C_P_Climbing2 的 Speed_muti 变为原来的十倍

import "StdLibrary.fcc" as std
import "Hud.fcc" as hud
import "../Player/C_P_Climbing2.fcg" as C_P_Climbing2

[platform_client]
graph C_WingshopUI {

	event OnAwake() {
	}

	// 点击 Speed_muti*10 按钮时，将攀爬速度变为原来的十倍
	func SpeedBoost_button(button entity<UIWidgetButton>, triggerPlayer entity<Player>) {
		C_P_Climbing2.Speed_muti = C_P_Climbing2.Speed_muti * 10
		LogInfo("Speed_muti: " + C_P_Climbing2.Speed_muti)
	}
}
