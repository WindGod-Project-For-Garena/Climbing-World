// Wingshop 根节点挂载的客户端脚本
// BUY{N}_button 仅向服务端派发购买请求；服务端校验金币通过后回推 __Custom6event___WingBuyUnlock__ 至客户端
// 客户端收到回推后才更新 HighestWingIndex 和 WingSpeed

import "StdLibrary.fcc" as std
import "Map.fcc" as map
import "Hud.fcc" as hud
import "../Player/C_P_Climbing2.fcg" as C_P_Climbing2
import "../Player/C_PlayerWingsData.fcg" as C_PlayerWingsData
import "EditorGenLib.fcc" as gen
import "Avatar.fcc" as avatar


[platform_client]
graph C_WingshopUI {
	bone entity<SkeletonPart> = nil

	event OnAwake() {
	}

	// 服务端验证购买成功后回推，客户端同步解锁状态和翅膀速度
	event __Custom6event___WingBuyUnlock__(triggerPlayer entity<Player>, wingIndex int) {
		if triggerPlayer != GetLocalPlayer() {
			return
		}
		triggerPlayer<C_PlayerWingsData>.HighestWingIndex = wingIndex
		triggerPlayer<C_PlayerWingsData>.PlayerNameToHighestWingIndex[triggerPlayer] = wingIndex
		var speed = GetWingGameplaySpeed(wingIndex)
		triggerPlayer<C_P_Climbing2>.WingSpeed = speed
		triggerPlayer<C_P_Climbing2>.WingSpeedDecay = speed
		DispatchEventToEntity(__Custom6event_SetCurrentSpeed__, globalEntity, PlatformType.Server, List<object>{triggerPlayer, speed})
		bone = GetSkeletonPartByName(triggerPlayer, "bone_Left_Spine_Backpack")
		DispatchEventToEntity(__Custom6event_ShowWingSelect__, globalEntity, PlatformType.Server, List<object>{triggerPlayer, wingIndex, bone})
	}

	// 翅膀在游戏内的实际速度值（与 UI 显示速度不同）
	func GetWingGameplaySpeed(wingIndex int) float {
		if wingIndex == 1  { return 58 }
		if wingIndex == 2  { return 116 }
		if wingIndex == 3  { return 232 }
		if wingIndex == 4  { return 464 }
		if wingIndex == 5  { return 928 }
		if wingIndex == 6  { return 1856 }
		if wingIndex == 7  { return 3712 }
		if wingIndex == 8  { return 7424 }
		if wingIndex == 9  { return 14848 }
		if wingIndex == 10 { return 29696 }
		if wingIndex == 11 { return 59392 }
		if wingIndex == 12 { return 118784 }
		return 58
	}

	func Close_button(button entity<UIWidgetButton>, triggerPlayer entity<Player>) {
		DispatchEventToEntity(__Custom6event_WingshopLeave__, globalEntity, PlatformType.Server, List<object>{triggerPlayer})
	}

	// Wing{N}_button：点击已解锁翅膀，切换速度和外观
	func Wing1_button(button entity<UIWidgetButton>, triggerPlayer entity<Player>) {
		if 1 <= triggerPlayer<C_PlayerWingsData>.HighestWingIndex {
			bone = GetSkeletonPartByName(triggerPlayer, "bone_Left_Spine_Backpack")
			DispatchEventToEntity(__Custom6event_ShowWingSelect__, globalEntity, PlatformType.Server, List<object>{triggerPlayer, 1, bone})
			triggerPlayer<C_P_Climbing2>.WingSpeed = 58
			triggerPlayer<C_P_Climbing2>.WingSpeedDecay = 58
			DispatchEventToEntity(__Custom6event_SetCurrentSpeed__, globalEntity, PlatformType.Server, List<object>{triggerPlayer, 58})
		}
	}

	func Wing2_button(button entity<UIWidgetButton>, triggerPlayer entity<Player>) {
		if 2 <= triggerPlayer<C_PlayerWingsData>.HighestWingIndex {
			DispatchEventToEntity(__Custom6event_ShowWingSelect__, globalEntity, PlatformType.Server, List<object>{triggerPlayer, 2, bone})
			triggerPlayer<C_P_Climbing2>.WingSpeed = 116
			triggerPlayer<C_P_Climbing2>.WingSpeedDecay = 116
			DispatchEventToEntity(__Custom6event_SetCurrentSpeed__, globalEntity, PlatformType.Server, List<object>{triggerPlayer, 116})
		}
	}

